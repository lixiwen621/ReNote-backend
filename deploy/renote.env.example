# 复制到服务器后改名为 renote.env，填真实值，权限建议 chmod 600
# systemd 示例：EnvironmentFile=/opt/renote/renote.env
#
# 不要提交含真实密码的 renote.env 到 Git

SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:mysql://127.0.0.1:3306/renote?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
DB_USERNAME=renote
DB_PASSWORD=请修改为强密码

JWT_SECRET=请修改为至少256位随机串用于生产HS256

JWT_EXPIRATION_MS=86400000

# 企业微信（按需）
WECHAT_ENABLED=true
WECHAT_MOCK_SUCCESS=false
WECHAT_CORP_ID=
WECHAT_AGENT_ID=0
WECHAT_SECRET=
WECHAT_CALLBACK_TOKEN=
WECHAT_CALLBACK_ENCODING_AES_KEY=

# 前端正式访问来源，逗号分隔
CORS_ALLOWED_ORIGINS=https://你的前端域名

# SQL 注入拦截（可选）
SQL_INJECTION_ENABLED=true
SQL_INJECTION_BLOCK=true
